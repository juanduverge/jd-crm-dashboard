        "jsCode": "const allowed = ['prospects','outreach','pipeline','messages','config','inbox','campaigns','optout','search_log','web_leads','tareas','contactos','notas'];\nconst q = ($input.first().json.query) || {};\nconst sheet = String(q.sheet || '').trim();\nif (!allowed.includes(sheet)) {\n  throw new Error('Invalid sheet param: ' + sheet);\n}\nreturn [{ json: { sheet } }];"
