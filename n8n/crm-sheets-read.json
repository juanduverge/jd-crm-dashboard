        "jsCode": "const v = $json.values || [];\nif (v.length === 0) return [{ json: { rows: [] } }];\nconst headers = v[0];\nconst rows = v.slice(1).map(r => {\n  const o = {};\n  headers.forEach((h, i) => { o[h] = r[i] != null ? r[i] : ''; });\n  return o;\n});\nreturn [{ json: { rows } }];"
      },
