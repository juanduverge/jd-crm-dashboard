        "html": "=<div style=\"font-family:Arial,sans-serif;max-width:560px\"><h2 style=\"color:#ff5c33\">Nuevo lead desde la web</h2><table style=\"border-collapse:collapse;font-size:14px\"><tr><td style=\"padding:4px 12px 4px 0;color:#666\">Nombre</td><td><b>{{ $('Validar y Preparar').item.json.nombre }}</b></td></tr><tr><td style=\"padding:4px 12px 4px 0;color:#666\">Empresa</td><td>{{ $('Validar y Preparar').item.json.empresa || '—' }}</td></tr><tr><td style=\"padding:4px 12px 4px 0;color:#666\">Email</td><td><a href=\"mailto:{{ $('Validar y Preparar').item.json.email }}\">{{ $('Validar y Preparar').item.json.email }}</a></td></tr><tr><td style=\"padding:4px 12px 4px 0;color:#666\">Teléfono</td><td>{{ $('Validar y Preparar').item.json.telefono || '—' }}</td></tr><tr><td style=\"padding:4px 12px 4px 0;color:#666\">Asunto</td><td>{{ $('Validar y Preparar').item.json.asunto || '—' }}</td></tr></table><p style=\"margin-top:16px;padding:12px;background:#f6f6f6;border-radius:8px\">{{ $('Validar y Preparar').item.json.mensaje }}</p><p style=\"font-size:12px;color:#999\">Página: {{ $('Validar y Preparar').item.json.pagina }} · Gestiónalo en el CRM → Inbox de Leads</p></div>",
