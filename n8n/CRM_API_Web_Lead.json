    {
      "parameters": {
        "jsCode": "// Valida el payload del formulario web, filtra bots (honeypot) y arma la fila\n// para la hoja web_leads. Acciones: create (default) | update (gestion desde CRM).\nconst req = $input.first().json;\nconst b = req.body || {};\nconst headers = req.headers || {};\nif (b.website) return [{ json: { skip: true } }];\nconst norm = (v) => String(v ?? '').trim();\nconst email = norm(b.email).toLowerCase();\nconst nombre = norm(b.nombre);\nconst esUpdate = b.action === 'update' && norm(b.id);\nif (!esUpdate && (!email || !email.includes('@') || !nombre)) return [{ json: { skip: true } }];\nfunction hash(s){let x=5381;for(let i=0;i<s.length;i++){x=((x<<5)+x+s.charCodeAt(i))|0;}return (x>>>0).toString(36);}\nconst now = new Date();\nconst dia = now.toISOString().slice(0,10);\nconst id = norm(b.id) || 'WL-' + hash(email + '|' + norm(b.detalle||b.mensaje) + '|' + dia);\nconst row = { id };\nif (esUpdate) {\n  if (b.estado) row.estado = norm(b.estado);\n  if (b.responsable !== undefined) row.responsable = norm(b.responsable);\n  if (b.notas_internas !== undefined) row.notas_internas = norm(b.notas_internas);\n  if (b.prioridad !== undefined) row.prioridad = norm(b.prioridad);\n  if (b.etiquetas !== undefined) row.etiquetas = norm(b.etiquetas);\n  row.actualizado = now.toISOString();\n} else {\n  Object.assign(row, {\n    fecha_hora: now.toISOString(), nombre, email,\n    empresa: norm(b.empresa), telefono: norm(b.telefono),\n    asunto: norm(b.tema||b.asunto), mensaje: norm(b.detalle||b.mensaje),\n    pagina: norm(b.pagina), url: norm(b.url), referrer: norm(b.referrer),\n    utm_source: norm(b.utm_source), utm_medium: norm(b.utm_medium), utm_campaign: norm(b.utm_campaign),\n    ip: norm(headers['cf-connecting-ip']||headers['x-forwarded-for']),\n    user_agent: norm(headers['user-agent']).slice(0,200),\n    fuente: 'web', formulario: norm(b.formulario)||'contacto',\n    estado: 'nuevo', responsable: '', notas_internas: '',\n    prioridad: 'media', etiquetas: '',\n    actualizado: now.toISOString(),\n  });\n}\nreturn [{ json: row }];"
      },
