# ============================================================
# JD Developer CRM — Variables de entorno
# Copia este archivo a ".env" y completa los valores.
# NUNCA subas .env al repositorio.
#
# ⚠️ SEGURIDAD CRÍTICA: TODA variable VITE_* se HORNEA en el bundle
# del cliente y es visible por cualquiera que abra la app. NO es un
# secreto. Ver docs/SEGURIDAD_FASE2.md.
#   - La protección real de acceso la da Cloudflare Access (Zero-Trust),
#     no VITE_APP_PASSWORD.
#   - La API key de n8n NO se define aquí ni se lee en el cliente: la
#     inyecta nginx server-side en el proxy /n8n-api. Ver deploy/nginx.conf.template.
# ============================================================

# --- Supabase (backend: DB, Auth, Storage) ---
# URL y llave publicable (anon). Ambas son seguras en el bundle del cliente.
# La SUPABASE_SECRET_KEY (service_role) NUNCA va aquí: solo en n8n / Edge Functions.
VITE_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_..."

# --- Autenticación del dashboard (LEGACY, en retirada) ---
# Ya no se usa tras migrar a Supabase Auth. Mantener solo si aún queda
# algún flujo viejo apuntando a config.appPassword. Sin fallback público.
VITE_APP_PASSWORD="cambia-esto"

# --- n8n (motor de automatización) ---
VITE_N8N_URL="https://backoffice.jddeveloper.com"
# NO existe VITE_N8N_API_KEY: el cliente llama a /n8n-api (mismo origen) y
# nginx inyecta la key real server-side (deploy/nginx.conf.template).

# --- Google Sheets ---
VITE_GOOGLE_SHEETS_ID="1N8bL-ujDDg9hF9gqV0mQrD94AZeh_QItJ-Aft2Xd7NE"
# API key de Google (Sheets API v4) para lectura directa. Si se deja vacío,
# el CRM usa datos de ejemplo y/o lectura vía n8n.
VITE_GOOGLE_API_KEY=""

# --- CRM API (webhooks n8n como proxy de Sheets) ---
# Token compartido opcional que validan los webhooks (header X-CRM-TOKEN).
# Déjalo vacío si tus webhooks no validan token.
VITE_N8N_HOOK_TOKEN=""

# --- Claude (Anthropic) — usado vía n8n, no directo desde el navegador ---
VITE_CLAUDE_VIA_N8N="true"

# --- IDs de workflows existentes en n8n ---
VITE_WF_ENVIO_EMAILS="ITdsEWd94R8ptUlb"
VITE_WF_SEGUIMIENTO_EMAIL="ZMQkvDXtD2tdMuYN"
VITE_WF_WHATSAPP_SEGUIMIENTO="JM3bEVBWajjmcCvV"

# --- Datos de negocio ---
VITE_BUSINESS_EMAIL_MAIN="info@jddeveloper.com"
VITE_BUSINESS_EMAIL_OUTREACH="sales@jddeveloper.com"
VITE_BUSINESS_WHATSAPP="+1 849 576 4367"
VITE_BUSINESS_BOOKING="https://calendar.app.google/QQ17ujMKjNXePb1a8"
